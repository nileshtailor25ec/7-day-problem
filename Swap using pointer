#include <iostream>
using namespace std;
void swap(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}
int main() {
    int x, y;
    cout << "Enter two numbers to swap: ";
    cin >> x >> y;
    swap(&x, &y);
    cout << "After swapping -> x: " << x << ", y: " << y << endl;
    return 0;
}

